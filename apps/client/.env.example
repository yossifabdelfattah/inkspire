# ──────────────────────────────────────────────
# Inkspire Client — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# All variables are exposed to the browser at build time, so they must be
# prefixed with VITE_ and must not contain any secrets. The Firebase Web App
# config below is public by design.

# ── API ───────────────────────────────────────
# Base URL of the Inkspire backend, including the /api path.
# Local default: http://localhost:5000/api
VITE_API_URL=

# ── Firebase Web App ──────────────────────────
# 1. Go to https://console.firebase.google.com
# 2. Select your project → Project Settings → General
# 3. Scroll to "Your apps" → select or create a Web App
# 4. Copy the firebaseConfig values below

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — only present if Google Analytics is enabled for the web app.
VITE_FIREBASE_MEASUREMENT_ID=
