# ──────────────────────────────────────────────
# Inkspire Server — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control — it contains service-account secrets.

# ── Server ────────────────────────────────────
# Port the Express/Socket.IO server listens on. Local default: 5000
PORT=5000

# MongoDB connection string.
# Local default: mongodb://127.0.0.1:27017/fullstack-ecommerce
# For MongoDB Atlas, use the full SRV connection string from the Atlas UI.
MONGO_URI=

# Node environment: development | production
NODE_ENV=development

# Origin allowed to make CORS and Socket.IO requests to this API.
# This must match the client's URL exactly. Local default: http://localhost:5173
CLIENT_URL=

# ── Firebase Admin SDK (server-side token verification) ──
# 1. Go to Firebase Console → Project Settings → Service Accounts
# 2. Click "Generate new private key" to download a JSON file
# 3. Copy the three values below from that JSON file
#
# If these are left blank, the server still boots, but any endpoint that
# requires authentication returns 503 until they are configured.

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=

# IMPORTANT: The private key must be a single-line string with literal \n characters.
# Copy exactly as shown in the downloaded JSON file.
# Example: "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# The server converts the literal \n sequences back into real newlines at runtime.
FIREBASE_PRIVATE_KEY=

# ── Optional ──────────────────────────────────
# Raises the Google Books API rate limit for book-request metadata lookups.
# Leave blank to use the unauthenticated (rate-limited) API.
GOOGLE_BOOKS_API_KEY=
