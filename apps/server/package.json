{
  "name": "server",
  "private": true,
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "tsx src/seed/seed.ts",
    "seed:fresh": "tsx src/seed/seed.ts --fresh",
    "seed:stores": "tsx src/seed/seedStores.ts",
    "dev:seed": "npm run seed && npm run dev"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "firebase-admin": "^13.10.0",
    "mongoose": "^8.23.1",
    "morgan": "^1.10.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
